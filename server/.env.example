# VisAgent Server 环境配置
PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173

# Database
DB_PATH=./data/visagent.db

# LLM Provider (OpenAI-compatible API)
# --- OpenAI ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# DEFAULT_MODEL=gpt-4o

# --- DeepSeek (推荐) ---
LLM_PROVIDER=deepseek
OPENAI_API_KEY=sk-29b6f1ce9bc3444b8f55464ae708d0ae
OPENAI_BASE_URL=https://api.deepseek.com/v1
DEFAULT_MODEL=deepseek-chat

# 也支持其他 OpenAI 兼容的服务商：
# 通义千问:  OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Moonshot:  OPENAI_BASE_URL=https://api.moonshot.cn/v1
# 本地 Ollama: OPENAI_BASE_URL=http://localhost:11434/v1

# Sandbox
SANDBOX_MAX_TIMEOUT=30000
SANDBOX_MAX_MEMORY=128
