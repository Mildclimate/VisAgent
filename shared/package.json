{
  "name": "@visagent/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared types and constants for VisAgent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types/*": {
      "types": "./dist/types/*.d.ts",
      "import": "./dist/types/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint ok'"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
